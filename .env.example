# ── MarketLens — Environment Variables ────────────────────────────────────────
# Copy this file to .env.local for local development.
# All variables marked REQUIRED must be set for the app to function.
# Variables marked OPTIONAL have graceful fallbacks.

# ── Upstash Redis (KV snapshots) ──────────────────────────────────────────────
# REQUIRED. Add via Vercel marketplace → Storage → Upstash Redis.
# Vercel injects these automatically when the integration is connected.
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token

# ── Vercel Blob (history time-series) ─────────────────────────────────────────
# REQUIRED. Add via Vercel marketplace → Storage → Blob.
# Vercel injects BLOB_READ_WRITE_TOKEN automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── FRED API key ──────────────────────────────────────────────────────────────
# REQUIRED in production. Register free at https://fred.stlouisfed.org/docs/api/api_key.html
# Without this key the app falls back to the public CSV endpoint (no key needed
# locally, but the CSV endpoint is rate-limited and less reliable).
FRED_API_KEY=your_fred_api_key_here

# ── Cron authentication ───────────────────────────────────────────────────────
# REQUIRED. A long random string used to authenticate Vercel cron invocations.
# Generate with: openssl rand -hex 32
# Set the same value in Vercel → Settings → Environment Variables.
# Used by /api/cron/daily and /api/cron/weekly.
CRON_SECRET=your_random_secret_here

# ── App URL (for OG metadata) ─────────────────────────────────────────────────
# OPTIONAL. Used to build canonical and Open Graph URLs in metadata.
# Defaults to https://markets-lens.vercel.app if unset.
NEXT_PUBLIC_APP_URL=https://your-custom-domain.com

# ── Vercel platform variables (injected automatically) ───────────────────────
# Do NOT set these manually — Vercel provides them at runtime.
# Listed here for documentation only.
#
# VERCEL_URL                       — preview deployment URL (no https://)
# VERCEL_PROJECT_PRODUCTION_URL    — production URL (no https://)
# NODE_ENV                         — "production" | "development" | "test"
